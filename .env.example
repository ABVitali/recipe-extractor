# Database
DATABASE_URL=postgres://user:password@localhost:5432/recipes?sslmode=disable

# LLM (OpenAI-compatible endpoint)
LLM_BASE_URL=http://localhost:8317/v1/
LLM_API_KEY=sk-...
LLM_MODEL=claude-opus-4-6

# PDF processing
# MAX_PAGES_PER_CHUNK controls how many pages are sent to the LLM at once
MAX_PAGES_PER_CHUNK=5
